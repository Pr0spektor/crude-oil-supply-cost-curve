# Copy this file to `.env` and paste your own key. `.env` is git-ignored.
#
#     cp .env.example .env
#     $EDITOR .env
#
# The repo runs fully WITHOUT any key: every figure and every number in INSIGHT_MEMO.md
# is reproduced from the sourced dataset bundled in src/data.py. A key is only needed
# to refresh prices from the live EIA feed.

# U.S. Energy Information Administration — crude price series.
# Free key, issued instantly: https://www.eia.gov/opendata/register.php
EIA_API_KEY=
